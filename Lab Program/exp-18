import pandas as pd

data = {
    "Chennai":[32,33,34,35,36,34,33],
    "Mumbai":[30,31,29,32,33,31,30],
    "Delhi":[28,30,35,36,34,33,32],
    "Bangalore":[25,26,27,26,25,24,26]
}

df = pd.DataFrame(data)

mean_temp = df.mean()
std_temp = df.std()

temp_range = df.max() - df.min()

print("Mean Temperature:\n", mean_temp)
print("\nStandard Deviation:\n", std_temp)
print("\nCity with highest range:", temp_range.idxmax())
print("Most consistent city:", std_temp.idxmin())
