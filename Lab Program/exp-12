import pandas as pd

# Sample sales data
data = {
    "product": ["Laptop","Mobile","Tablet","Laptop","Mobile","Laptop","Headphones","Tablet","Mobile","Laptop"],
    "quantity": [5,10,3,7,4,6,8,2,9,1]
}

df = pd.DataFrame(data)

# Total quantity sold for each product
product_sales = df.groupby("product")["quantity"].sum()

# Top 5 products
top5 = product_sales.sort_values(ascending=False).head(5)

print("Top 5 Most Sold Products:")
print(top5)
